{
  "name": "From Address Limiter",
  "description": "This is an empty module for testing purposes.",
  "documentation": "README.md",
  "namespace": "JHU\\fromaddresslimiter",
  "authors": [
    {
      "name": "Michael Sherman Jr",
      "email": "msherm12@jh.edu",
      "institution": "Johns Hopkins University"
    }
  ],
  "system-settings":
  [
    {
      "key": "domain-list",
      "name": "Allowed Domain List i.e.(@google.com,@yahoo.com)",
      "required": true,
      "type": "text"
    },

    {
      "key": "action-to-take",
      "name": "Action to take on button click",
      "required": true,
      "type": "radio",
      "choices": [
        {
          "value": "Disabled",
          "name": "Disabled"
        },
        {
          "value": "Notify",
          "name": "<span title=\"Display a notification, that when closed will continue with the button action\">Notify (warning)</span>"
        },
        {
          "value": "Prevent",
          "name": "<span title=\"Display a notification, that when closed will not perform the button action\">Prevent (block)</span>"
        }
      ]
    },
    {
      "key": "display-message",
      "name": "Notification message",
      "required": true,
      "type": "rich-text"
    }
  ],
  "framework-version": 14
}